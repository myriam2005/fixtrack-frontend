# ── Backend Configuration ──────────────────────────────────────────────────────

# Database
MONGODB_URI=mongodb://localhost:27017/fixtrack

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# ── Email Configuration (Gmail, Office365, Sendgrid, etc.) ──────────────────────

# SMTP Server
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Email credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# From address (shows in "From" field)
EMAIL_FROM=noreply@fixtrack.local

# Optional: N8n webhook for automation
N8N_WEBHOOK_TICKET_CREATED=https://your-n8n-instance.com/webhook/...
N8N_WEBHOOK_TICKET_ASSIGNED=https://your-n8n-instance.com/webhook/...
N8N_WEBHOOK_WELCOME_USER=https://your-n8n-instance.com/webhook/...
N8N_WEBHOOK_TICKET_RESOLVED=https://your-n8n-instance.com/webhook/...

# ── Notes ──────────────────────────────────────────────────────────────────────
# Gmail: Use "App Passwords" for EMAIL_PASS (https://myaccount.google.com/apppasswords)
# Office365: Use your email and password
# SendGrid: Use "apikey" as username and your API key as password
# Note: EMAIL_SECURE should be "true" for port 465, "false" for port 587
